# ==========================================
# Army81 — متغيرات البيئة
# انسخ هذا الملف إلى .env واملأ القيم
# ==========================================

# Google / Gemini (مطلوب للبدء)
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id

# Anthropic Claude (للمهام الحرجة)
ANTHROPIC_API_KEY=your_anthropic_key_here

# البحث على الإنترنت — اختر واحداً
SERPER_API_KEY=your_serper_key_here        # serper.dev — أسهل
# NEWSAPI_KEY=your_newsapi_key_here        # اختياري للأخبار

# Google Cloud (للنشر لاحقاً)
GCP_PROJECT_ID=your_project_id
GCP_REGION=us-central1

# Ollama (للنماذج المحلية — اختياري)
OLLAMA_URL=http://localhost:11434

# إعدادات النظام
LOG_LEVEL=INFO
PORT=8181
