# Army81 Environment Variables
# Copy this file to .env and fill in your API keys

# === Local Models (Ollama) ===
OLLAMA_HOST=http://localhost:11434

# === Cloud Providers (Optional - for premium tasks) ===
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-...
SONAR_API_KEY=pplx-...

# === Media Generation (Optional) ===
HEYGEN_API_KEY=
ELEVENLABS_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# === Storage (Optional) ===
DROPBOX_API_KEY=

# === Other AI Providers (Optional) ===
GEMINI_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=
OPENROUTER_API_KEY=
